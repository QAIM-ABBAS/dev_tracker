# --------------------------------------------------------------------------- #
# ProjectFlow environment configuration                                       #
# Copy to `.env` and adjust as needed.                                        #
# --------------------------------------------------------------------------- #

# PostgreSQL
POSTGRES_USER=projectflow
POSTGRES_PASSWORD=projectflow
POSTGRES_DB=projectflow

# Webhook shared secret — required header `X-ProjectFlow-Webhook-Secret`
# for any call to /api/v1/webhooks/*
WEBHOOK_SECRET=change-me-in-production

# Comma-separated extra CORS origins (optional)
# EXTRA_CORS_ORIGINS=http://my-host:3000
